{
    "version": 2,
    "builds": [
        {
            "src": "client/dist/**",
            "use": "@vercel/static"
        },
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/(.*)",
            "dest": "/client/dist/$1"
        }
    ],
    "build": {
        "env": {
            "BUILD_COMMAND": "cd client && npm run build",
            "OUTPUT_DIRECTORY": "client/dist"
        }
    }
}